# Single-image deploy for RunPod (vLLM GPU + gateway in one container).
# Built on the official vLLM image so CUDA/torch/vLLM are already present and
# consistent — we only add the (light) gateway + OCR + embeddings on top.
#
# Build & push to a registry RunPod can pull (Docker Hub / GHCR):
#   docker build -f Dockerfile.runpod -t <you>/slm-runpod:latest .
#   docker push <you>/slm-runpod:latest
# Then create a RunPod GPU Pod from that image, expose HTTP port 8080, and set
# env GATEWAY_API_KEYS + (optional) HUGGING_FACE_HUB_TOKEN. See DEPLOYMENT.md §RunPod.
FROM vllm/vllm-openai:latest

ENV PIP_NO_CACHE_DIR=1 PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1

# System libs for PaddleOCR / PDF rasterization + curl for the readiness probe.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 libglib2.0-0 libgomp1 curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Light gateway deps (none pull torch, so vLLM's CUDA torch stays intact).
COPY requirements.txt requirements-ocr.txt ./
RUN pip install -r requirements.txt

# Embeddings: install sentence-transformers WITHOUT deps so it can't downgrade
# vLLM's torch; add the few runtime extras it needs that may be missing.
RUN pip install --no-deps sentence-transformers==3.3.1 \
    && pip install "scikit-learn>=1.3" "scipy>=1.10"

# OCR: CPU PaddleOCR by default (reliable in any CUDA image). To use the GPU for
# OCR too, install a CUDA-matched paddlepaddle-gpu (see requirements-ocr-gpu.txt)
# and set OCR_USE_GPU=true. OCR init failures degrade to CPU/native automatically.
RUN pip install -r requirements-ocr.txt || echo "OCR deps optional; continuing without them"

COPY app ./app
COPY scripts ./scripts

ENV LLM_BACKEND=openai_upstream \
    UPSTREAM_API_KEY=novllmkeyneeded \
    MODEL_NAME=Qwen/Qwen3-8B \
    SERVED_MODEL_ID=slm-qwen3-8b \
    FORCE_MODEL=true \
    ENABLE_THINKING=false \
    DOMAIN_REASONING=false \
    EMBEDDINGS_MODE=local \
    OCR_ENABLED=true \
    OCR_VERSION=v5 \
    OCR_USE_GPU=false \
    WARMUP_ON_START=true \
    QUANTIZATION=fp8 \
    MAX_NUM_SEQS=24 \
    PORT=8080

EXPOSE 8080
# Override the base image's vLLM entrypoint; our script runs vLLM + gateway.
ENTRYPOINT []
CMD ["bash", "scripts/runpod_start.sh"]
