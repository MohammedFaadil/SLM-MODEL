# =============================================================================
#  PRODUCTION config — Windows GPU server + Ollama + (optional) MSSQL
#  Copy to `.env` on the server and fill in the marked values.
# =============================================================================

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Gateway auth (THIS is the "API key" the product will use) ----
# Put a strong random value. The product sends it as its OpenAI api key.
# Rotating = change here and in the product. Comma-separate to allow several.
GATEWAY_API_KEYS=CHANGE-ME-to-a-long-random-key

# Restrict to the product's origin(s) if browsers call the API directly.
CORS_ALLOW_ORIGINS=*

# ---- Model backend: vLLM on the GPU box (Ollama alt shown below) ----
LLM_BACKEND=openai_upstream
UPSTREAM_BASE_URL=http://localhost:8000/v1     # vLLM. Ollama alt: http://localhost:11434/v1
UPSTREAM_API_KEY=novllmkeyneeded
# The served id (== vLLM --served-model-name). Keep stable across precision swaps.
# Ollama alt for a Windows box: qwen3:8b-q8_0 (near-fp16, best practical accuracy).
MODEL_NAME=Qwen/Qwen3-8B
SERVED_MODEL_ID=slm-qwen3-8b
FORCE_MODEL=true
# Reasoning/sampling are the PRODUCT's choice (forwarded verbatim) — no server flag.
REQUEST_TIMEOUT=600
WARMUP_ON_START=true

# ---- Embeddings (/v1/embeddings) ----
EMBEDDINGS_MODE=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- OCR (POST /api/ocr/parse) ----
OCR_ENABLED=true
OCR_VERSION=v5          # needs paddleocr>=3.0
OCR_LANG=en
# TRUE on a GPU host IF you installed paddlepaddle-gpu and the LLM isn't saturating
# VRAM. Bad/missing GPU paddle degrades to CPU automatically.
OCR_USE_GPU=false
OCR_PREFER_NATIVE_TEXT=true
OCR_DPI=300
OCR_MAX_PAGES=30
OCR_USE_DOC_ORIENTATION=false

# ---- MSSQL persistence (OPTIONAL) --------------------------------------------
# Leave BOTH blank to run stateless. When set, adds request/audit logging only.
# Requires: pip install -r requirements-db.txt  AND  ODBC Driver 18 for SQL Server.
#
# Easiest: one full URL (note the URL-encoded driver name):
# DATABASE_URL=mssql+pyodbc://sqluser:sqlpass@DBHOST:1433/SLM_DB?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes&Encrypt=yes
#
# Or provide the parts and we build the URL:
# MSSQL_HOST=DBHOST
# MSSQL_PORT=1433
# MSSQL_DATABASE=SLM_DB
# MSSQL_USER=sqluser
# MSSQL_PASSWORD=sqlpass
# MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# MSSQL_TRUST_CERT=true
# MSSQL_ENCRYPT=true
# (For Windows Integrated auth, set MSSQL_HOST + MSSQL_DATABASE and leave
#  MSSQL_USER/PASSWORD blank — a Trusted_Connection URL is built for you.)
PERSIST_REQUESTS=true
