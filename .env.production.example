# =============================================================================
#  PRODUCTION config — Windows GPU server + Ollama + (optional) MSSQL
#  Copy to `.env` on the server and fill in the marked values.
# =============================================================================

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Gateway auth (THIS is the "API key" the product will use) ----
# Put a strong random value. The product sends it as its OpenAI api key.
# Rotating = change here and in the product. Comma-separate to allow several.
GATEWAY_API_KEYS=CHANGE-ME-to-a-long-random-key

# Restrict to the product's origin(s) if browsers call the API directly.
CORS_ALLOW_ORIGINS=*

# ---- Model backend: Ollama on the same Windows GPU box ----
LLM_BACKEND=openai_upstream
UPSTREAM_BASE_URL=http://localhost:11434/v1
UPSTREAM_API_KEY=ollama
# Default qwen3:8b is Q4 (fast). For higher accuracy on a GPU with headroom use a
# higher-precision tag, e.g. qwen3:8b-q8_0, or step up to qwen3:14b.
MODEL_NAME=qwen3:8b
SERVED_MODEL_ID=slm-qwen3-8b
FORCE_MODEL=true
# Speed vs. reasoning. Leave off for fast, clean JSON; turn on if you have GPU
# headroom and want deeper reasoning on hard matches.
ENABLE_THINKING=false
# Reasoning for long-form domain tasks. OFF = much faster (recommended). ON = a
# bit more thorough but ~2-3x slower.
DOMAIN_REASONING=false
# Reproducible output: greedy decoding + fixed seed (same input -> same result).
DETERMINISTIC=true
LLM_SEED=42
REQUEST_TIMEOUT=600
WARMUP_ON_START=true

# ---- Embeddings (semantic skill matching) ----
EMBEDDINGS_MODE=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SEMANTIC_MATCH_THRESHOLD=0.62

# ---- OCR ----
OCR_ENABLED=true
OCR_VERSION=v5
OCR_LANG=en
# Recommended TRUE on a GPU host IF you installed paddlepaddle-gpu (see
# requirements-ocr-gpu.txt) and the LLM isn't saturating VRAM. CPU OCR is fine for
# normal resume volumes. Bad/missing GPU paddle degrades to CPU automatically.
OCR_USE_GPU=false
OCR_PREFER_NATIVE_TEXT=true

# ---- MSSQL persistence (OPTIONAL) --------------------------------------------
# Leave BOTH blank to run stateless (the product still works — this only adds
# audit logs + job/candidate/match history). Requires: pip install -r
# requirements-db.txt  AND  Microsoft ODBC Driver 18 for SQL Server on the host.
#
# Easiest: one full URL (note the URL-encoded driver name):
# DATABASE_URL=mssql+pyodbc://sqluser:sqlpass@DBHOST:1433/SLM_DB?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes&Encrypt=yes
#
# Or provide the parts and we build the URL:
# MSSQL_HOST=DBHOST
# MSSQL_PORT=1433
# MSSQL_DATABASE=SLM_DB
# MSSQL_USER=sqluser
# MSSQL_PASSWORD=sqlpass
# MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# MSSQL_TRUST_CERT=true
# MSSQL_ENCRYPT=true
# (For Windows Integrated auth, set MSSQL_HOST + MSSQL_DATABASE and leave
#  MSSQL_USER/PASSWORD blank — a Trusted_Connection URL is built for you.)
PERSIST_REQUESTS=true
