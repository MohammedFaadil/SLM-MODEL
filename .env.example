# =============================================================================
#  SLM Gateway configuration
#  Copy to `.env` and adjust. Everything has a sane default for LOCAL CPU use.
# =============================================================================

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Gateway auth (what YOUR platform sends as the OpenAI api key) ----
# Leave empty = no auth (fine for localhost testing).
# In the cloud, set one or more keys (comma separated). Your platform then uses
# ANY of these as its "OPENAI_API_KEY". This is the value you rotate/replace.
GATEWAY_API_KEYS=

# ---- LLM backend ----
# openai_upstream = proxy to an OpenAI-compatible server (Ollama locally, vLLM in cloud)
# mock            = no model needed; deterministic canned answers (plumbing tests only)
LLM_BACKEND=openai_upstream

# Where the real model lives.
#   Local (Ollama):  http://localhost:11434/v1
#   Cloud (vLLM):    http://vllm:8000/v1   (or your served URL)
UPSTREAM_BASE_URL=http://localhost:11434/v1
UPSTREAM_API_KEY=ollama

# The actual model the gateway routes every request to.
#   Ollama tag:      qwen3:8b
#   vLLM served id:  Qwen/Qwen3-8B
MODEL_NAME=qwen3:8b

# The id we advertise to your platform at /v1/models and echo back in responses.
SERVED_MODEL_ID=slm-qwen3-8b

# If true, whatever model name your platform sends (e.g. "gpt-4o") is IGNORED and
# routed to MODEL_NAME. Keep true so no code change is needed on the platform side.
FORCE_MODEL=true

# Qwen3 "thinking" mode. off = faster + clean JSON (best for CPU + extraction).
# Turn on only for hard reasoning if you have GPU headroom.
ENABLE_THINKING=false

# Upstream call timeout (seconds). CPU inference is slow — keep this generous.
REQUEST_TIMEOUT=600

# ---- Embeddings (semantic skill matching) ----
# local    = sentence-transformers in-process (recommended, works offline)
# upstream = ask the OpenAI-compatible backend for embeddings
# off      = disable; matching falls back to fuzzy string overlap
EMBEDDINGS_MODE=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Cosine score >= this counts two skills/phrases as the "same" skill.
SEMANTIC_MATCH_THRESHOLD=0.62

# ---- OCR (PaddleOCR PP-OCRv4 / v5) ----
OCR_ENABLED=true
# v5 = PP-OCRv5 (latest, best), v4 = PP-OCRv4 (lighter). Auto-falls-back if v5 model absent.
OCR_VERSION=v5
OCR_LANG=en
OCR_USE_GPU=false
# Resumes are usually text PDFs. Try fast native extraction first; only OCR the
# pages that come back empty (scanned/image resumes). Set false to always OCR.
OCR_PREFER_NATIVE_TEXT=true
# Render DPI when rasterizing PDF pages for OCR. Higher = more accurate, slower.
OCR_DPI=200

# ---- Uploads ----
MAX_UPLOAD_MB=25
